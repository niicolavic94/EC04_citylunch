<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}CityLunch{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <style>
        body { background-color: #f8f9fa; }
        .navbar-brand { font-weight: 700; font-size: 1.4rem; }
        .navbar { box-shadow: 0 2px 8px rgba(0,0,0,.08); }
        .card { border: none; box-shadow: 0 2px 8px rgba(0,0,0,.07); }
        .table thead { background-color: #ff6b35; color: #fff; }
        .btn-primary { background-color: #ff6b35; border-color: #ff6b35; }
        .btn-primary:hover { background-color: #e55a25; border-color: #e55a25; }
        .badge-role { background-color: #ff6b35; }
        .hero { background: linear-gradient(135deg, #ff6b35 0%, #f7931e 100%); color: #fff; border-radius: 1rem; }
    </style>
</head>
<body>
<nav class="navbar navbar-expand-lg navbar-dark" style="background-color:#ff6b35;">
    <div class="container">
        <a class="navbar-brand" href="{{ path('home') }}">🍱 CityLunch</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navMenu">
            <ul class="navbar-nav ms-auto">
                <li class="nav-item">
                    <a class="nav-link" href="{{ path('web_produits') }}"><i class="bi bi-box-seam"></i> Produits</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="{{ path('web_livreurs') }}"><i class="bi bi-person-badge"></i> Livreurs</a>
                </li>
            </ul>
        </div>
    </div>
</nav>

<div class="container mt-4">
    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>{{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>{{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}

    {% block body %}{% endblock %}
</div>

<footer class="text-center text-muted py-4 mt-5">
    <small>CityLunch API &copy; {{ "now"|date("Y") }} — Nicolas REDON</small>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
{% block javascripts %}{% endblock %}
</body>
</html>
