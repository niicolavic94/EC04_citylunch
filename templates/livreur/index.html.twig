{% extends 'base.html.twig' %}

{% block title %}Livreurs — CityLunch{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0"><i class="bi bi-person-badge me-2"></i>Livreurs</h2>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalAjout">
        <i class="bi bi-plus-lg"></i> Ajouter un livreur
    </button>
</div>

<div class="card mb-4">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Nom</th>
                    <th>Email</th>
                    <th>Produits dans le sac</th>
                    <th>Créé le</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for livreur in livreurs %}
                <tr>
                    <td>{{ livreur.id }}</td>
                    <td class="fw-semibold">{{ livreur.nom }}</td>
                    <td>{{ livreur.email }}</td>
                    <td>
                        {% if livreur.sac %}
                            <span class="badge bg-primary">{{ livreur.sac.sacProduits|length }} produit(s)</span>
                        {% else %}
                            <span class="text-muted">—</span>
                        {% endif %}
                    </td>
                    <td>{{ livreur.createdAt|date('d/m/Y') }}</td>
                    <td>
                        <button class="btn btn-sm btn-outline-primary me-1"
                            data-bs-toggle="modal"
                            data-bs-target="#modalEdit{{ livreur.id }}">
                            <i class="bi bi-pencil"></i>
                        </button>
                        <form method="post" action="{{ path('web_livreurs_delete', {id: livreur.id}) }}" class="d-inline"
                            onsubmit="return confirm('Supprimer ce livreur ?')">
                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                    </td>
                </tr>

                {# Modal édition #}
                <div class="modal fade" id="modalEdit{{ livreur.id }}" tabindex="-1">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title">Modifier — {{ livreur.nom }}</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            </div>
                            <form method="post" action="{{ path('web_livreurs_update', {id: livreur.id}) }}">
                                <div class="modal-body">
                                    <div class="mb-3">
                                        <label class="form-label">Nom</label>
                                        <input type="text" name="nom" class="form-control" value="{{ livreur.nom }}" required>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">Email</label>
                                        <input type="email" name="email" class="form-control" value="{{ livreur.email }}" required>
                                    </div>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                                    <button type="submit" class="btn btn-primary">Enregistrer</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
                {% else %}
                <tr>
                    <td colspan="6" class="text-center text-muted py-4">Aucun livreur enregistré.</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

{# Modal ajout #}
<div class="modal fade" id="modalAjout" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Ajouter un livreur</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" action="{{ path('web_livreurs_create') }}">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Nom <span class="text-danger">*</span></label>
                        <input type="text" name="nom" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email <span class="text-danger">*</span></label>
                        <input type="email" name="email" class="form-control" required>
                    </div>
                    <div class="alert alert-info mb-0">
                        <i class="bi bi-info-circle me-1"></i> Un mot de passe sera généré et envoyé par email au livreur.
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Ajouter</button>
                </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}
