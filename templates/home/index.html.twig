{% extends 'base.html.twig' %}

{% block title %}CityLunch — Accueil{% endblock %}

{% block body %}
<div class="hero p-5 mb-4 text-center">
    <h1 class="display-5 fw-bold">🍱 CityLunch</h1>
    <p class="lead">Gestion des produits et des livreurs</p>
</div>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card h-100 text-center p-4">
            <div class="display-4 mb-2">📦</div>
            <h3 class="fw-bold" style="color:#ff6b35;">{{ nbProduits }}</h3>
            <p class="text-muted mb-3">Produits enregistrés</p>
            <a href="{{ path('web_produits') }}" class="btn btn-primary">Gérer les produits</a>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100 text-center p-4">
            <div class="display-4 mb-2">🚴</div>
            <h3 class="fw-bold" style="color:#ff6b35;">{{ nbLivreurs }}</h3>
            <p class="text-muted mb-3">Livreurs enregistrés</p>
            <a href="{{ path('web_livreurs') }}" class="btn btn-primary">Gérer les livreurs</a>
        </div>
    </div>
</div>
{% endblock %}
